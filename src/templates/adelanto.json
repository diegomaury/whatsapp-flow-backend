{
  "routing_model": {
    "WELCOME": [
      "LOCATION"
    ],
    "LOCATION": [
      "PROPERTY"
    ],
    "PROPERTY": [
      "VALUE"
    ],
    "VALUE": [
      "ESTIMATE"
    ],
    "ESTIMATE": [
      "AUTHORIZATION"
    ],
    "AUTHORIZATION": [
      "SUMMARY"
    ],
    "SUMMARY": [
      "COMPLETE_YES",
      "COMPLETE_NO"
    ]
  },
  "data_api_version": "4.0",
  "version": "7.3",
  "screens": [
    {
      "id": "WELCOME",
      "title": "¿Necesitas un adelanto de la venta de tu propiedad?",
      "data": {
        "city": {
          "type": "string",
          "__example__": "Monterrey"
        },
        "state": {
          "type": "string",
          "__example__": "Nuevo León"
        },
        "colonias": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              }
            }
          },
          "__example__": [
            {
              "id": "San Pedro Garza García",
              "title": "San Pedro Garza García"
            },
            {
              "id": "Cumbres",
              "title": "Cumbres"
            },
            {
              "id": "Del Valle",
              "title": "Del Valle"
            }
          ]
        },
        "logo_fliphouse": {
          "type": "string",
          "__example__": "data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAADUlEQVR42mNk+M9QDwADhgGAWjR9awAAAABJRU5ErkJggg=="
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Image",
            "src": "${data.logo_fliphouse}",
            "width": 300,
            "height": 100,
            "scale-type": "contain",
            "alt-text": "Logo Fliphouse"
          },
          {
            "type": "TextHeading",
            "text": "¿Necesitas un adelanto de la venta de tu propiedad?"
          },
          {
            "type": "TextBody",
            "text": "Cuéntanos sobre tu propiedad y te explicamos qué opciones tienes disponibles, sin costo ni compromiso."
          },
          {
            "type": "Form",
            "name": "welcome_form",
            "children": [
              {
                "type": "EmbeddedLink",
                "text": "Ver Aviso de Privacidad",
                "on-click-action": {
                  "name": "open_url",
                  "url": "https://fliphouse.mx/aviso-de-privacidad"
                }
              },
              {
                "type": "OptIn",
                "name": "acepta_privacidad",
                "label": "He leído y acepto el Aviso de Privacidad de Fliphouse",
                "required": true
              }
            ]
          },
          {
            "type": "Footer",
            "label": "Empezar",
            "on-click-action": {
              "name": "navigate",
              "next": {
                "type": "screen",
                "name": "LOCATION"
              },
              "payload": {}
            }
          }
        ]
      }
    },
    {
      "id": "LOCATION",
      "title": "Tu ubicación",
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextCaption",
            "text": "Paso 1 de 6"
          },
          {
            "type": "TextBody",
            "text": "Vemos que tu propiedad está en ${screen.WELCOME.data.city}, ${screen.WELCOME.data.state}. ¿En qué colonia o zona queda?"
          },
          {
            "type": "Form",
            "name": "location_form",
            "children": [
              {
                "type": "Dropdown",
                "name": "colonia_propiedad",
                "label": "Colonia o zona",
                "required": true,
                "data-source": "${screen.WELCOME.data.colonias}"
              }
            ]
          },
          {
            "type": "Footer",
            "label": "Continuar",
            "on-click-action": {
              "name": "navigate",
              "next": {
                "type": "screen",
                "name": "PROPERTY"
              },
              "payload": {}
            }
          }
        ]
      }
    },
    {
      "id": "PROPERTY",
      "title": "Tu propiedad",
      "sensitive": [
        "tiene_escrituras"
      ],
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextCaption",
            "text": "Paso 2 de 6"
          },
          {
            "type": "TextHeading",
            "text": "Tu propiedad"
          },
          {
            "type": "Form",
            "name": "property_form",
            "children": [
              {
                "type": "RadioButtonsGroup",
                "name": "tipo_propiedad",
                "label": "¿Qué tipo de propiedad es?",
                "required": true,
                "data-source": [
                  { "id": "Casa", "title": "Casa" },
                  { "id": "Departamento", "title": "Departamento" },
                  { "id": "Otro", "title": "Otro" }
                ]
              },
              {
                "type": "RadioButtonsGroup",
                "name": "tiene_escrituras",
                "label": "¿Tienes escrituras?",
                "required": true,
                "data-source": [
                  { "id": "Sí", "title": "Sí" },
                  { "id": "No", "title": "No" },
                  { "id": "Aún no lo sé", "title": "Aún no lo sé" }
                ]
              }
            ]
          },
          {
            "type": "Footer",
            "label": "Continuar",
            "on-click-action": {
              "name": "navigate",
              "next": {
                "type": "screen",
                "name": "VALUE"
              },
              "payload": {}
            }
          }
        ]
      }
    },
    {
      "id": "VALUE",
      "title": "Valor de tu propiedad",
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextCaption",
            "text": "Paso 3 de 6"
          },
          {
            "type": "TextCaption",
            "text": "No tiene que ser exacto — un aproximado está bien."
          },
          {
            "type": "Form",
            "name": "value_form",
            "children": [
              {
                "type": "TextInput",
                "name": "valor_aproximado_de_tu_propiedad",
                "label": "¿En cuánto estimas el valor?",
                "label-variant": "large",
                "input-type": "number",
                "required": true,
                "helper-text": "En pesos mexicanos"
              }
            ]
          },
          {
            "type": "Footer",
            "label": "Ver mi estimado",
            "on-click-action": {
              "name": "data_exchange",
              "payload": {
                "valor_aproximado_de_tu_propiedad": "${form.valor_aproximado_de_tu_propiedad}"
              }
            }
          }
        ]
      }
    },
    {
      "id": "ESTIMATE",
      "title": "Tu adelanto estimado",
      "data": {
        "valor_display": {
          "type": "string",
          "__example__": "$2,000,000"
        },
        "adelanto_min": {
          "type": "string",
          "__example__": "$400,000"
        },
        "adelanto_max": {
          "type": "string",
          "__example__": "$600,000"
        },
        "money_icon": {
          "type": "string",
          "__example__": "data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAADUlEQVR42mNk+M9QDwADhgGAWjR9awAAAABJRU5ErkJggg=="
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Image",
            "src": "${data.money_icon}",
            "width": 120,
            "height": 120,
            "scale-type": "contain",
            "alt-text": "Adelanto estimado"
          },
          {
            "type": "TextCaption",
            "text": "Paso 4 de 6"
          },
          {
            "type": "TextBody",
            "text": "Con una propiedad de ${data.valor_display}, podrías recibir un adelanto de entre ${data.adelanto_min} y ${data.adelanto_max}."
          },
          {
            "type": "TextCaption",
            "text": "Este es un estimado referencial. El monto final depende de la evaluación legal, física y de mercado, y se formaliza ante notario."
          },
          {
            "type": "Footer",
            "label": "Quiero que me contacten",
            "on-click-action": {
              "name": "navigate",
              "next": {
                "type": "screen",
                "name": "AUTHORIZATION"
              },
              "payload": {}
            }
          }
        ]
      }
    },
    {
      "id": "AUTHORIZATION",
      "title": "¿Seguimos?",
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextCaption",
            "text": "Paso 5 de 6"
          },
          {
            "type": "TextBody",
            "text": "Viste que tu propiedad podría generar un adelanto de entre ${screen.ESTIMATE.data.adelanto_min} y ${screen.ESTIMATE.data.adelanto_max}. ¿Quieres que un asesor de Fliphouse revise tu caso y te explique cómo funciona? Sin compromiso."
          },
          {
            "type": "Form",
            "name": "authorization_form",
            "children": [
              {
                "type": "RadioButtonsGroup",
                "name": "acepto_continuar",
                "label": "¿Te interesa que te contactemos?",
                "required": true,
                "data-source": [
                  { "id": "si", "title": "Sí, me interesa" },
                  { "id": "no", "title": "Ahorita no" }
                ]
              }
            ]
          },
          {
            "type": "Footer",
            "label": "Finalizar",
            "on-click-action": {
              "name": "navigate",
              "next": {
                "type": "screen",
                "name": "SUMMARY"
              },
              "payload": {}
            }
          }
        ]
      }
    },
    {
      "id": "SUMMARY",
      "title": "Revisa tu información",
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextCaption",
            "text": "Paso 6 de 6"
          },
          {
            "type": "TextBody",
            "text": "📍 ${screen.WELCOME.data.city} — ${screen.LOCATION.form.colonia_propiedad}"
          },
          {
            "type": "TextBody",
            "text": "🏠 ${screen.PROPERTY.form.tipo_propiedad} · Escrituras: ${screen.PROPERTY.form.tiene_escrituras}"
          },
          {
            "type": "TextBody",
            "text": "💰 Valor estimado: ${screen.VALUE.form.valor_aproximado_de_tu_propiedad}"
          },
          {
            "type": "TextBody",
            "text": "✅ Adelanto estimado: ${screen.ESTIMATE.data.adelanto_min} – ${screen.ESTIMATE.data.adelanto_max}"
          },
          {
            "type": "Footer",
            "label": "Confirmar y finalizar",
            "on-click-action": {
              "name": "data_exchange",
              "payload": {
                "city": "${screen.WELCOME.data.city}",
                "state": "${screen.WELCOME.data.state}",
                "colonia_propiedad": "${screen.LOCATION.form.colonia_propiedad}",
                "tipo_propiedad": "${screen.PROPERTY.form.tipo_propiedad}",
                "tiene_escrituras": "${screen.PROPERTY.form.tiene_escrituras}",
                "valor_aproximado_de_tu_propiedad": "${screen.VALUE.form.valor_aproximado_de_tu_propiedad}",
                "adelanto_min": "${screen.ESTIMATE.data.adelanto_min}",
                "adelanto_max": "${screen.ESTIMATE.data.adelanto_max}",
                "acepto_continuar": "${screen.AUTHORIZATION.form.acepto_continuar}"
              }
            }
          }
        ]
      }
    },
    {
      "id": "COMPLETE_YES",
      "title": "¡Todo listo!",
      "terminal": true,
      "success": true,
      "data": {
        "city": {
          "type": "string",
          "__example__": "Monterrey"
        },
        "state": {
          "type": "string",
          "__example__": "Nuevo León"
        },
        "colonia_propiedad": {
          "type": "string",
          "__example__": "San Pedro Garza García"
        },
        "tipo_propiedad": {
          "type": "string",
          "__example__": "Casa"
        },
        "tiene_escrituras": {
          "type": "string",
          "__example__": "Sí"
        },
        "valor_aproximado_de_tu_propiedad": {
          "type": "string",
          "__example__": "2000000"
        },
        "adelanto_min": {
          "type": "string",
          "__example__": "$400,000"
        },
        "adelanto_max": {
          "type": "string",
          "__example__": "$600,000"
        },
        "acepto_continuar": {
          "type": "string",
          "__example__": "si"
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "¡Todo listo!"
          },
          {
            "type": "TextBody",
            "text": "Ya tenemos tu información. En breve un asesor de Fliphouse te contactará para revisar tu caso contigo."
          },
          {
            "type": "TextCaption",
            "text": "Sin compromiso de tu parte. Puedes pausar o cancelar cuando quieras."
          },
          {
            "type": "Footer",
            "label": "Cerrar",
            "on-click-action": {
              "name": "complete",
              "payload": {
                "city": "${data.city}",
                "state": "${data.state}",
                "colonia_propiedad": "${data.colonia_propiedad}",
                "tipo_propiedad": "${data.tipo_propiedad}",
                "tiene_escrituras": "${data.tiene_escrituras}",
                "valor_aproximado_de_tu_propiedad": "${data.valor_aproximado_de_tu_propiedad}",
                "adelanto_min": "${data.adelanto_min}",
                "adelanto_max": "${data.adelanto_max}",
                "acepto_continuar": "${data.acepto_continuar}",
                "estado": "completado"
              }
            }
          }
        ]
      }
    },
    {
      "id": "COMPLETE_NO",
      "title": "Entendido, sin problema.",
      "terminal": true,
      "success": false,
      "data": {
        "city": {
          "type": "string",
          "__example__": "Monterrey"
        },
        "state": {
          "type": "string",
          "__example__": "Nuevo León"
        },
        "colonia_propiedad": {
          "type": "string",
          "__example__": "San Pedro Garza García"
        },
        "tipo_propiedad": {
          "type": "string",
          "__example__": "Casa"
        },
        "tiene_escrituras": {
          "type": "string",
          "__example__": "Sí"
        },
        "valor_aproximado_de_tu_propiedad": {
          "type": "string",
          "__example__": "2000000"
        },
        "adelanto_min": {
          "type": "string",
          "__example__": "$400,000"
        },
        "adelanto_max": {
          "type": "string",
          "__example__": "$600,000"
        },
        "acepto_continuar": {
          "type": "string",
          "__example__": "no"
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Entendido, sin problema."
          },
          {
            "type": "TextBody",
            "text": "Gracias por tu tiempo. No te contactaremos. Cuando quieras retomarlo, este chat sigue abierto."
          },
          {
            "type": "TextCaption",
            "text": "Tu información queda guardada de forma segura y no la compartimos con nadie."
          },
          {
            "type": "Footer",
            "label": "Cerrar",
            "on-click-action": {
              "name": "complete",
              "payload": {
                "city": "${data.city}",
                "state": "${data.state}",
                "colonia_propiedad": "${data.colonia_propiedad}",
                "tipo_propiedad": "${data.tipo_propiedad}",
                "tiene_escrituras": "${data.tiene_escrituras}",
                "valor_aproximado_de_tu_propiedad": "${data.valor_aproximado_de_tu_propiedad}",
                "adelanto_min": "${data.adelanto_min}",
                "adelanto_max": "${data.adelanto_max}",
                "acepto_continuar": "${data.acepto_continuar}",
                "estado": "completado"
              }
            }
          }
        ]
      }
    }
  ]
}
{
  "version": "7.3",
  "data_api_version": "4.0",
  "routing_model": {
    "WELCOME": ["LOCATION"],
    "LOCATION": ["PROPERTY"],
    "PROPERTY": ["VALUE"],
    "VALUE": ["ESTIMATE"],
    "ESTIMATE": ["AUTHORIZATION"],
    "AUTHORIZATION": ["SUMMARY"],
    "SUMMARY": ["COMPLETE_YES", "COMPLETE_NO"]
  },
  "screens": [
    {
      "id": "WELCOME",
      "title": "Sofí de Fliphouse",
      "data": {
        "city": { "type": "string", "__example__": "Torreón" },
        "state": { "type": "string", "__example__": "Coahuila" },
        "logo_fliphouse": { "type": "string", "__example__": "data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAADUlEQVR42mNk+M9QDwADhgGAWjR9awAAAABJRU5ErkJggg==" },
        "colonias": {
          "type": "array",
          "items": { "type": "object", "properties": { "id": {"type": "string"}, "title": {"type": "string"} } },
          "__example__": [{ "id": "1", "title": "Centro" }]
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          { "type": "Image", "src": "${data.logo_fliphouse}", "width": 300, "height": 100, "scale-type": "contain" },
          { "type": "TextHeading", "text": "¡Hola! Soy Sofí." },
          { "type": "TextBody", "text": "Te ayudaremos a obtener un adelanto por tu propiedad en ${data.city}." },
          { "type": "Footer", "label": "Empezar", "on-click-action": { "name": "navigate", "next": { "type": "screen", "name": "LOCATION" }, "payload": {} } }
        ]
      }
    },
    {
      "id": "LOCATION",
      "title": "Ubicación",
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          { "type": "TextBody", "text": "Confirma la zona de tu propiedad:" },
          { "type": "Dropdown", "name": "colonia_propiedad", "label": "Selecciona colonia", "data-source": "${screen.WELCOME.data.colonias}", "required": true },
          { "type": "Footer", "label": "Continuar", "on-click-action": { "name": "navigate", "next": { "type": "screen", "name": "PROPERTY" }, "payload": {} } }
        ]
      }
    },
    {
      "id": "PROPERTY",
      "title": "Propiedad",
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          { "type": "RadioButtonsGroup", "name": "tipo_propiedad", "label": "Tipo de inmueble", "data-source": [{ "id": "casa", "title": "Casa" }, { "id": "depto", "title": "Departamento" }], "required": true },
          { "type": "Footer", "label": "Siguiente", "on-click-action": { "name": "navigate", "next": { "type": "screen", "name": "VALUE" }, "payload": { "error_message": "" } } }
        ]
      }
    },
    {
      "id": "VALUE",
      "title": "Valor Estimado",
      "data": { "error_message": { "type": "string", "__example__": "" } },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          { "type": "TextInput", "name": "valor_aproximado_de_tu_propiedad", "label": "Valor en MXN", "input-type": "number", "required": true },
          { 
            "type": "TextBody", 
            "text": "${data.error_message}", 
            "visible": "${data.error_message != ''}" 
          },
          { "type": "Footer", "label": "Calcular Adelanto", "on-click-action": { "name": "data_exchange", "payload": { "valor_aproximado_de_tu_propiedad": "${form.valor_aproximado_de_tu_propiedad}" } } }
        ]
      }
    },
    {
      "id": "ESTIMATE",
      "title": "Tu Propuesta",
      "data": {
        "valor_display": { "type": "string", "__example__": "$0" },
        "adelanto_min": { "type": "string", "__example__": "$0" },
        "adelanto_max": { "type": "string", "__example__": "$0" },
        "money_icon": { "type": "string", "__example__": "data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAADUlEQVR42mNk+M9QDwADhgGAWjR9awAAAABJRU5ErkJggg==" }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          { "type": "Image", "src": "${data.money_icon}", "width": 80, "height": 80 },
          { "type": "TextHeading", "text": "${data.adelanto_min} a ${data.adelanto_max}" },
          { "type": "Footer", "label": "Me interesa", "on-click-action": { "name": "navigate", "next": { "type": "screen", "name": "AUTHORIZATION" }, "payload": {} } }
        ]
      }
    },
    {
      "id": "AUTHORIZATION",
      "title": "Contacto",
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          { "type": "RadioButtonsGroup", "name": "acepto_continuar", "label": "¿Quieres que te contactemos?", "data-source": [{ "id": "si", "title": "Sí" }, { "id": "no", "title": "No" }], "required": true },
          { "type": "Footer", "label": "Siguiente", "on-click-action": { "name": "navigate", "next": { "type": "screen", "name": "SUMMARY" }, "payload": {} } }
        ]
      }
    },
    {
      "id": "SUMMARY",
      "title": "Resumen",
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          { "type": "TextBody", "text": "Propiedad en: ${screen.WELCOME.data.city}" },
          { "type": "Footer", "label": "Finalizar", "on-click-action": { "name": "data_exchange", "payload": { "acepto_continuar": "${screen.AUTHORIZATION.form.acepto_continuar}", "colonia_propiedad": "${screen.LOCATION.form.colonia_propiedad}", "tipo_propiedad": "${screen.PROPERTY.form.tipo_propiedad}", "valor_aproximado_de_tu_propiedad": "${screen.VALUE.form.valor_aproximado_de_tu_propiedad}" } } }
        ]
      }
    },
    {
      "id": "COMPLETE_YES",
      "title": "¡Éxito!",
      "terminal": true,
      "success": true,
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          { "type": "TextHeading", "text": "Solicitud enviada" },
          { "type": "Footer", "label": "Cerrar", "on-click-action": { "name": "complete", "payload": {} } }
        ]
      }
    },
    {
      "id": "COMPLETE_NO",
      "title": "Cancelado",
      "terminal": true,
      "success": false,
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          { "type": "TextBody", "text": "Proceso terminado." },
          { "type": "Footer", "label": "Cerrar", "on-click-action": { "name": "complete", "payload": {} } }
        ]
      }
    }
  ]
}
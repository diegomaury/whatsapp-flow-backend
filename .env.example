# ─────────────────────────────────────────────
# Servidor
# ─────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─────────────────────────────────────────────
# WhatsApp Cloud API
# ─────────────────────────────────────────────
API_TOKEN=your_system_user_token_here
BUSINESS_PHONE=your_phone_number_id_here
API_VERSION=v20.0
FLOW_ID=your_flow_id_here
FLOW_ID_ADELANTO=your_adelanto_flow_id_here
FLOW_ID_LISTING=your_listing_flow_id_here

# ─────────────────────────────────────────────
# Webhook
# ─────────────────────────────────────────────
WEBHOOK_VERIFY_TOKEN=mi_token_secreto_unico
# App Secret (Meta → App Dashboard → Settings → Basic)
APP_SECRET=your_app_secret_here

# ─────────────────────────────────────────────
# Flow Endpoint — Cifrado RSA
# ─────────────────────────────────────────────
# Opción A: ruta al archivo PEM (recomendado en producción)
PRIVATE_KEY_PATH=./keys/private_key.pem

# Opción B: clave inline (escapa los saltos de línea con \n)
# PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQ...\n-----END PRIVATE KEY-----"

# ─────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# REDIS_TLS=true   # descomentar si el servidor Redis requiere TLS (Railway, Upstash, etc.)

# ─────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/whatsapp_flows
# DATABASE_SSL=true   # descomentar para Railway/Fly.io/Render
PG_POOL_MAX=10

# ─────────────────────────────────────────────
# Make.com
# ─────────────────────────────────────────────
# Webhook de Make para mensajes entrantes de WA (escenario WA_Inbound)
MAKE_WA_INBOUND_URL=https://hook.make.com/your_inbound_webhook_here
# Secret compartido entre Make y Railway para POST /send-message
MAKE_SECRET=un_token_secreto_largo_y_aleatorio

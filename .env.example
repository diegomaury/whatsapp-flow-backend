# ─────────────────────────────────────────────
# Servidor
# ─────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─────────────────────────────────────────────
# WhatsApp Cloud API
# ─────────────────────────────────────────────
API_TOKEN=your_system_user_token_here
BUSINESS_PHONE=your_phone_number_id_here
API_VERSION=v20.0
FLOW_ID=your_flow_id_here

# ─────────────────────────────────────────────
# Webhook
# ─────────────────────────────────────────────
WEBHOOK_VERIFY_TOKEN=mi_token_secreto_unico
# App Secret (Meta → App Dashboard → Settings → Basic)
APP_SECRET=your_app_secret_here

# ─────────────────────────────────────────────
# Flow Endpoint — Cifrado RSA
# ─────────────────────────────────────────────
# Opción A: ruta al archivo PEM (recomendado en producción)
PRIVATE_KEY_PATH=./keys/private_key.pem

# Opción B: clave inline (escapa los saltos de línea con \n)
# PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQ...\n-----END PRIVATE KEY-----"

# ─────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# REDIS_TLS=true   # descomentar si el servidor Redis requiere TLS (Railway, Upstash, etc.)

# ─────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/whatsapp_flows
# DATABASE_SSL=true   # descomentar para Railway/Fly.io/Render
PG_POOL_MAX=10

# ─────────────────────────────────────────────
# Flow Exchange (Adelanto) — clave RSA inline
# ─────────────────────────────────────────────
# Clave privada específica para /flow/exchange (prioridad sobre PRIVATE_KEY_PATH).
# Escapa los saltos de línea con \n (una sola línea en el archivo .env).
# FLOW_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQ...\n-----END PRIVATE KEY-----"

# ─────────────────────────────────────────────
# Make.com — Webhooks
# ─────────────────────────────────────────────
# Webhook genérico: se llama cuando /flow principal detecta un COMPLETE
MAKE_WEBHOOK_URL=https://hook.us1.make.com/your_generic_hook_id

# Webhook del Flow Adelanto: se llama desde /flow/exchange cuando action=COMPLETE
MAKE_WA_INBOUND_WEBHOOK_URL=https://hook.us1.make.com/your_adelanto_hook_id
